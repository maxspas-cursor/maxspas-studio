# Telegram Bot API token from @BotFather
BOT_TOKEN=your_bot_token_here

# Bot username without @ (from getMe after /newbot)
BOT_USERNAME=maxspas_studio_bot

# Your numeric Telegram chat id (get it from @userinfobot)
ADMIN_CHAT_ID=your_telegram_chat_id_here

# Lead API (website contact form → Telegram admin)
LEAD_API_PORT=8787

# Comma-separated origins allowed for browser form POST (CORS)
# Local + CloudPub demo: add your https://*.cloudpub.ru site URL after publish-cloudpub.ps1
LEAD_API_CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8080,http://localhost:8080
